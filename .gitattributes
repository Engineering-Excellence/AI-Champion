# 텍스트 파일 자동 감지 후 LF 정규화
* text=auto

# 소스 코드 — LF 강제
*.py    text eol=lf
*.ipynb text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Windows 전용 스크립트 — CRLF 강제
*.bat   text eol=crlf

# 바이너리 — diff/merge 비활성화
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.xlsx  binary
*.xls   binary
*.docx  binary
*.pdf   binary
*.exe   binary
*.pyc   binary
*.spec  binary
